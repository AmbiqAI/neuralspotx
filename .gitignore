/build/
**/build/
.venv/
/site/
*.egg-info/
**/.DS_Store
**/__pycache__/
*.pyc

# Toolchain-variant build dirs (build_armclang/, build_gcc/, build_atfe/, etc.)
**/build_*/

# Local benchmark capture artifacts (Joulescope, UART logs, etc.)
examples/**/results/

# Vendored board source descriptor — regenerated into each example by
# `nsx sync` (the committed artifact is boards/<board>/board.cmake, so the
# redundant board.yaml copy is intentionally not tracked in examples).
examples/*/boards/*/board.yaml

# Auto-generated per-app cmake/.gitignore (it ignores the regenerated
# cmake/nsx/ build glue). The file itself is produced by `nsx sync`/`lock`,
# so it is not tracked either; hand-written cmake/presets/ stays tracked.
examples/*/cmake/.gitignore

# NSX per-app untracked state (advisory lock, etc.; created by nsx sync/lock/update)
**/.nsx/
