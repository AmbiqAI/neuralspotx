# NSX app build artifacts
build/

# Per-app untracked NSX state (advisory lock used by `nsx sync` / `nsx lock`
# / `nsx update` to serialise concurrent invocations). Safe to delete;
# recreated on demand.
.nsx/

# Module-level ignores are managed by modules/.gitignore
# (auto-generated by `nsx configure`).
# Registry modules are ignored; local modules (local: true) are kept.
